# Database connection
# 開発環境: ローカルのPostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/salarylens"

# 本番環境: Dockerネットワーク内のPostgreSQL
# DATABASE_URL="postgresql://postgres:postgres@postgres:5432/salarylens"

# PostgreSQL credentials (本番環境で変更すること)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=salarylens
