// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  paySlips  PaySlip[]
}

model PaySlip {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 支給日
  paymentDate       DateTime

  // 基本情報
  company           String
  employeeNumber    String?

  // 支給項目
  baseSalary        Decimal     @db.Decimal(12, 2)
  overtime          Decimal     @default(0) @db.Decimal(12, 2)
  bonus             Decimal     @default(0) @db.Decimal(12, 2)
  allowances        Decimal     @default(0) @db.Decimal(12, 2)

  // 控除項目
  healthInsurance   Decimal     @default(0) @db.Decimal(12, 2)
  pensionInsurance  Decimal     @default(0) @db.Decimal(12, 2)
  employmentIns     Decimal     @default(0) @db.Decimal(12, 2)
  incomeTax         Decimal     @default(0) @db.Decimal(12, 2)
  residentTax       Decimal     @default(0) @db.Decimal(12, 2)
  otherDeductions   Decimal     @default(0) @db.Decimal(12, 2)

  // 合計
  grossPay          Decimal     @db.Decimal(12, 2)
  totalDeductions   Decimal     @db.Decimal(12, 2)
  netPay            Decimal     @db.Decimal(12, 2)

  // メタデータ
  fileName          String?
  uploadedAt        DateTime    @default(now())
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([userId])
  @@index([paymentDate])
}
